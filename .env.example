# Variables d'environnement — emails de commande et de contact (Resend)
# Copiez ce fichier en .env (local) ou configurez-les dans Vercel (Production).
# Sans ces variables, la commande reste valide (confirmation WhatsApp) et le
# formulaire de contact renvoie « mail_not_configured » proprement.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=contact@cestmondessert.fr
CONTACT_FROM_EMAIL=C'est Mon Dessert <commande@cestmondessert.fr>
